---
const footerNav = [
  { text: "About", href: "/about" },
  { text: "Services", href: "/services" },
  { text: "Find a Partner Clinic", href: "/providers" },
  { text: "Blog", href: "/blog" },
  { text: "Get Started", href: "/get-started" },
  { text: "Contact", href: "/contact" },
];

const legalNav = [
  { text: "Privacy Policy", href: "/privacy-policy" },
  { text: "Terms of Service", href: "/terms" },
];
---

<footer class="bg-bema-green py-14 text-bema-white">
  <div class="container">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <a href="/" class="font-display text-3xl font-bold text-bema-white" aria-label="BEMA home">BEMA</a>
        <p class="mt-5 max-w-sm text-bema-white/85">[PLACEHOLDER: Founding sentence - to be populated]</p>
        <p class="mt-5 text-sm font-medium text-bema-white">A Florida 501(c)(3) nonprofit organization</p>
        <!-- TODO: Add EIN and registration number post-incorporation -->
      </div>

      <nav aria-label="Footer navigation">
        <h2 class="font-body text-lg font-semibold text-bema-white">Navigation</h2>
        <ul class="mt-5 space-y-3">
          {footerNav.map((item) => (
            <li>
              <a class="text-bema-white/85 transition-colors hover:text-bema-khaki" href={item.href}>{item.text}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div>
        <h2 class="font-body text-lg font-semibold text-bema-white">Legal and Info</h2>
        <ul class="mt-5 space-y-3">
          {legalNav.map((item) => (
            <li>
              <a class="text-bema-white/85 transition-colors hover:text-bema-khaki" href={item.href}>{item.text}</a>
            </li>
          ))}
          <li>[PLACEHOLDER: Mailing address]</li>
          <li>[PLACEHOLDER: General contact email]</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-bema-khaki/40 pt-6 text-sm text-bema-white/80">
      <p>&copy; 2026 BEMA Incorporated. All rights reserved.</p>
    </div>
  </div>
</footer>
