---
import Navigation from "./Navigation.astro";
---

<header class="sticky top-0 z-50 w-full border-b border-bema-khaki/40 bg-bema-green">
  <div class="container flex h-20 items-center justify-between gap-3 lg:gap-5">
    <a href="/" class="inline-flex items-center font-display text-3xl font-bold text-bema-white" aria-label="BEMA home">
      BEMA
    </a>

    <div class="flex items-center gap-2 lg:gap-3">
      <Navigation />
      <!-- TODO: Replace with live phone number at ops launch -->
      <a
        href="tel:0000000000"
        class="inline-flex min-h-11 items-center justify-center rounded-md border border-bema-white bg-bema-white px-4 py-2 text-sm font-medium text-bema-green transition-colors duration-200 hover:border-bema-khaki hover:bg-bema-khaki-light focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bema-khaki sm:px-5"
      >
        Call Us
      </a>
    </div>
  </div>
</header>
