---
const navItems = [
  { text: "Home", href: "/" },
  { text: "About", href: "/about" },
  { text: "Services", href: "/services" },
  { text: "Employers", href: "/employers" },
  { text: "Find a Partner Clinic", href: "/providers" },
  { text: "Blog", href: "/blog" },
  { text: "Get Started", href: "/get-started" },
  { text: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const isActivePath = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<nav class="hidden lg:block" aria-label="Primary navigation">
  <ul class="flex items-center gap-4 xl:gap-5">
    {navItems.map((item) => {
      const isActive = isActivePath(item.href);

      return (
        <li>
          <a
            href={item.href}
            class:list={[
              "text-sm font-medium text-bema-white underline-offset-8 transition-colors hover:text-bema-khaki",
              isActive && "font-semibold underline decoration-2 decoration-bema-khaki",
            ]}
            aria-current={isActive ? "page" : undefined}
          >
            {item.text}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<button
  id="mobile-menu-button"
  class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-md border border-bema-white/30 text-bema-white transition-colors hover:border-bema-khaki hover:text-bema-khaki lg:hidden"
  aria-label="Toggle menu"
  aria-expanded="false"
  aria-controls="mobile-menu"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16" />
  </svg>
</button>

<div
  id="mobile-menu"
  class="absolute left-0 right-0 top-20 hidden border-b border-bema-khaki/40 bg-bema-green px-4 py-5 lg:hidden"
  role="menu"
  aria-labelledby="mobile-menu-button"
>
  <div class="grid gap-2">
    {navItems.map((item) => {
      const isActive = isActivePath(item.href);

      return (
        <a
          href={item.href}
          class:list={[
            "rounded-md px-4 py-3 text-sm font-medium text-bema-white transition-colors hover:bg-bema-green-dark hover:text-bema-khaki",
            isActive && "font-semibold underline decoration-2 decoration-bema-khaki underline-offset-4",
          ]}
          role="menuitem"
          aria-current={isActive ? "page" : undefined}
        >
          {item.text}
        </a>
      );
    })}
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    const setMenuState = (isOpen) => {
      mobileMenu?.classList.toggle("hidden", !isOpen);
      mobileMenuButton?.setAttribute("aria-expanded", String(isOpen));
    };

    mobileMenuButton?.addEventListener("click", (event) => {
      event.stopPropagation();
      const isOpen = mobileMenuButton.getAttribute("aria-expanded") === "true";
      setMenuState(!isOpen);
    });

    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setMenuState(false));
    });

    document.addEventListener("click", (event) => {
      if (
        mobileMenu &&
        mobileMenuButton &&
        !mobileMenu.classList.contains("hidden") &&
        !mobileMenu.contains(event.target) &&
        !mobileMenuButton.contains(event.target)
      ) {
        setMenuState(false);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setMenuState(false);
    });
  });
</script>
