---
import Button from "../UI/Button.astro";

export interface Props {
  title?: string;
  subtitle?: string;
  placeholderLabel?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const {
  title = "[PLACEHOLDER: Primary hero headline - community-first, relief-emotion framing]",
  subtitle = "[PLACEHOLDER: One sentence describing BEMA as a coordination organization connecting Florida's working families to affordable care]",
  placeholderLabel = "[PLACEHOLDER: Hero image - working adult or family, Florida setting, warm and dignified, not clinical]",
  ctaText = "Get Started",
  ctaLink = "/get-started",
  secondaryCtaText = "Learn How It Works",
  secondaryCtaLink = "/#how-it-works",
} = Astro.props;
---

<section class="relative overflow-hidden bg-bema-green text-bema-white">
  <div role="img" aria-label={placeholderLabel} class="absolute inset-0 bg-bema-khaki-light/25">
    <div class="absolute inset-0 bg-bema-green/70"></div>
    <div class="absolute bottom-8 right-8 hidden max-w-md rounded-lg border border-bema-white/40 bg-bema-white/10 p-5 text-sm font-medium text-bema-white md:block">
      {placeholderLabel}
    </div>
  </div>

  <div class="container relative flex min-h-[76dvh] items-center py-24">
    <div class="max-w-4xl">
      <h1 class="text-bema-white">{title}</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-bema-white/90 md:text-2xl">{subtitle}</p>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button href={ctaLink} variant="inverted" size="lg">{ctaText}</Button>
        <Button href={secondaryCtaLink} variant="inverted-outline" size="lg">
          {secondaryCtaText}
        </Button>
      </div>
    </div>
  </div>
</section>
