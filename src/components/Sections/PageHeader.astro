---
export interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-bema-green py-16 text-bema-white md:py-24">
  <div class="container">
    <div class="max-w-4xl">
      <h1 class="text-bema-white">{title}</h1>
      {subtitle && <p class="mt-5 max-w-3xl text-lg leading-8 text-bema-white/90 md:text-xl">{subtitle}</p>}
    </div>
  </div>
</section>
