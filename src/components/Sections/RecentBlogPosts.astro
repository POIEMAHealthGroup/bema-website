---
import { getCollection } from "astro:content";
import Button from "../UI/Button.astro";
import ImagePlaceholder from "../UI/ImagePlaceholder.astro";
import { formatDate } from "../../utils/dateUtils";

export interface Props {
  count?: number;
  showViewAll?: boolean;
}

const { count = 3, showViewAll = true } = Astro.props;

const posts = (await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, count);
---

<section class="section-pad bg-bema-white">
  <div class="container">
    <div class="mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2>From the Blog</h2>
        <p class="mt-4 max-w-2xl text-lg text-bema-green/85">[PLACEHOLDER: Blog section intro - mission communication and community education]</p>
      </div>
      {showViewAll && <Button href="/blog" variant="outline">View All Posts</Button>}
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {posts.map((post) => (
        <article class="card flex h-full flex-col">
          <a href={`/blog/${post.slug}`} class="block">
            {post.data.image?.url ? (
              <img
                src={post.data.image.url}
                alt={post.data.image.alt}
                class="h-56 w-full rounded-t-lg object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <ImagePlaceholder label={post.data.image?.alt || "[PLACEHOLDER: Featured blog image]"} minHeight="min-h-56" class="rounded-b-none border-x-0 border-t-0" />
            )}
          </a>
          <div class="flex flex-1 flex-col p-6">
            <p class="text-sm font-medium text-bema-khaki">{formatDate(post.data.pubDate)} / {post.data.author}</p>
            <h3 class="mt-3 text-2xl">
              <a href={`/blog/${post.slug}`} class="hover:text-bema-green-dark">{post.data.title}</a>
            </h3>
            <p class="mt-4 flex-1 text-bema-green/85">{post.data.description}</p>
            <a href={`/blog/${post.slug}`} class="mt-6 font-semibold text-bema-green underline decoration-bema-khaki underline-offset-4 hover:text-bema-green-dark">
              Read More
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
