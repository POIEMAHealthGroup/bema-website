---
import { getCollection } from "astro:content";
import ImagePlaceholder from "../UI/ImagePlaceholder.astro";

const { showAll = true, limit = 3 } = Astro.props;

const allTeam = await getCollection("team", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const teamMembers = allTeam
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, showAll ? undefined : limit);
---

<section id="leadership" class="section-pad bg-bema-white">
  <div class="container">
    <div class="mb-12 max-w-3xl">
      <h2>[PLACEHOLDER: Leadership Team section heading]</h2>
      <p class="mt-4 text-lg text-bema-green/85">[PLACEHOLDER: Leadership Team section intro]</p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {teamMembers.map((member) => (
        <article class="card flex h-full flex-col">
          <ImagePlaceholder label={member.data.imageLabel} minHeight="min-h-72" class="rounded-b-none border-x-0 border-t-0" />
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-2xl">{member.data.name}</h3>
            <p class="mt-2 font-semibold text-bema-khaki">{member.data.title}</p>
            <p class="mt-4 text-bema-green/85">{member.data.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
