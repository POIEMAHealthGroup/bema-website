---
export interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline" | "inverted" | "inverted-outline" | "text";
  size?: "sm" | "md" | "lg";
  class?: string;
  target?: string;
  rel?: string;
  disabled?: boolean;
  type?: "button" | "submit" | "reset";
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  target,
  rel,
  disabled = false,
  type = "button",
  ariaLabel,
  ...rest
} = Astro.props;

const baseStyles = [
  "inline-flex items-center justify-center gap-2 rounded-md border font-body font-medium",
  "transition-colors duration-200",
  "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bema-khaki",
  "disabled:pointer-events-none disabled:opacity-60",
  "active:translate-y-px",
];

const sizeStyles = {
  sm: "min-h-10 px-4 py-2 text-sm",
  md: "min-h-11 px-5 py-3 text-base",
  lg: "min-h-12 px-6 py-3 text-base md:px-7",
};

const variantStyles = {
  primary: "border-bema-green bg-bema-green text-bema-white hover:border-bema-green-dark hover:bg-bema-green-dark",
  secondary: "border-bema-green bg-bema-white text-bema-green hover:border-bema-khaki hover:text-bema-green-dark",
  outline: "border-bema-green bg-bema-white text-bema-green hover:border-bema-khaki hover:text-bema-green-dark",
  inverted: "border-bema-white bg-bema-white text-bema-green hover:border-bema-khaki hover:bg-bema-khaki-light",
  "inverted-outline": "border-bema-white bg-transparent text-bema-white hover:bg-bema-white hover:text-bema-green",
  text: "border-transparent bg-transparent px-0 text-bema-green underline decoration-bema-khaki underline-offset-4 hover:text-bema-green-dark",
};

const classes = [
  ...baseStyles,
  sizeStyles[size],
  variantStyles[variant],
  className,
].join(" ");

const Element = href ? "a" : "button";
---

<Element
  href={href}
  class={classes}
  target={target}
  rel={target === "_blank" ? "noopener noreferrer" : rel}
  disabled={disabled}
  type={!href ? type : undefined}
  aria-label={ariaLabel}
  role={!href ? "button" : undefined}
  {...rest}
>
  <slot />
</Element>
