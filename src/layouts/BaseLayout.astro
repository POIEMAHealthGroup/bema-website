---
import "../assets/styles/global.css";
import Seo from "../components/UI/Seo.astro";
import Header from "../components/Global/Header.astro";
import Footer from "../components/Global/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: {
    url: string;
    alt: string;
  };
  type?: "website" | "article";
  canonicalUrl?: string;
}

const {
  title = "BEMA | Healthcare Access for Florida's Working Families",
  description = "[PLACEHOLDER: SEO meta description - 155 characters max]",
  image = {
    url: "/favicon.svg",
    alt: "[PLACEHOLDER: Alt text for BEMA wordmark image]",
  },
  type = "website",
  canonicalUrl,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <Seo
      title={title}
      description={description}
      image={image}
      type={type}
      canonicalUrl={canonicalUrl}
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-bema-khaki focus:px-4 focus:py-2 focus:text-bema-green" href="#main-content">
      Skip to content
    </a>
    <div class="flex min-h-screen flex-col bg-bema-white">
      <Header />
      <main id="main-content" class="flex-grow">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
