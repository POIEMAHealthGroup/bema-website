---
import PageHeader from "../components/Sections/PageHeader.astro";
import { formatDate } from "../utils/dateUtils";

export interface Props {
  title: string;
  description?: string;
  image?: {
    url: string;
    alt: string;
  };
  date?: Date;
  author?: string;
  tags?: string[];
}

const {
  title,
  image,
  date,
  author,
  tags = [],
} = Astro.props;

const formattedDate = date ? formatDate(date) : null;
---

<PageHeader title={title} subtitle="[PLACEHOLDER: Blog post page description]" />

<section class="section-pad bg-bema-white">
  <div class="container">
    <div class="mx-auto max-w-3xl">
      {image && (
        <img
          src={image.url}
          alt={image.alt}
          class="mb-10 h-auto w-full rounded-lg border border-bema-khaki/40 object-cover"
          loading="eager"
          decoding="async"
        />
      )}

      {(date || author || tags.length > 0) && (
        <div class="mb-8 border-b border-bema-khaki/40 pb-6">
          <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-medium text-bema-green/75">
            {formattedDate && <span>{formattedDate}</span>}
            {author && <span>{author}</span>}
          </div>
          {tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded-md border border-bema-khaki/50 px-3 py-1 text-xs font-semibold text-bema-green">{tag}</span>
              ))}
            </div>
          )}
        </div>
      )}

      <article class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-bema-green prose-p:text-bema-green/85 prose-li:text-bema-green/85 prose-strong:text-bema-green prose-a:text-bema-green hover:prose-a:text-bema-green-dark">
        <slot />
      </article>
    </div>
  </div>
</section>
