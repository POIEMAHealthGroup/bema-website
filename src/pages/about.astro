---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import TeamList from "../components/Sections/TeamList.astro";
import ImagePlaceholder from "../components/UI/ImagePlaceholder.astro";

const values = [
  {
    heading: "Dignity Before Profit",
    body: "[PLACEHOLDER: 1 sentence - anonymity in the sponsorship layer, member dignity]",
    path: "M12 3l7 4v5c0 4.2-2.6 7.8-7 9-4.4-1.2-7-4.8-7-9V7l7-4z",
  },
  {
    heading: "Radical Transparency",
    body: "[PLACEHOLDER: 1 sentence - 100% donor model, zero overhead on charitable dollars]",
    path: "M4 12s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6zm8 3a3 3 0 100-6 3 3 0 000 6z",
  },
  {
    heading: "Empathy in Action",
    body: "[PLACEHOLDER: 1 sentence - trusted guide framing, not a savior]",
    path: "M12 3l8 18-8-4-8 4 8-18z",
  },
  {
    heading: "Whole-Person Care",
    body: "[PLACEHOLDER: 1 sentence - integrated network, Primary Care plus Eye Care plus Mental Health]",
    path: "M7 8a4 4 0 118 0 4 4 0 01-8 0zm-4 12a6 6 0 0112 0M16 14a4 4 0 014 4v2",
  },
];
---

<BaseLayout
  title="About | BEMA - Healthcare Access for Florida's Working Families"
  description="[PLACEHOLDER: About page SEO description - 120 to 155 characters]"
>
  <PageHeader
    title="[PLACEHOLDER: About page headline]"
    subtitle="[PLACEHOLDER: One sentence organizational description]"
  />

  <section class="section-pad bg-bema-white">
    <div class="container">
      <figure class="mx-auto max-w-4xl text-center">
        <blockquote class="font-display text-3xl font-bold leading-tight text-bema-green md:text-5xl">
          [PLACEHOLDER: Founding sentence - the confirmed BEMA founding premise statement]
        </blockquote>
        <figcaption class="mt-6 font-semibold text-bema-khaki">The BEMA Mission</figcaption>
      </figure>
    </div>
  </section>

  <section class="section-pad bg-bema-white">
    <div class="container grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="eyebrow">Our story</p>
        <h2 class="mt-3">[PLACEHOLDER: &quot;Our Story&quot; or equivalent heading]</h2>
        <p class="mt-6 text-lg text-bema-green/85">[PLACEHOLDER: 2 paragraphs - founding context, the problem being solved, why BEMA was built]</p>
      </div>
      <ImagePlaceholder label="[PLACEHOLDER: Founders or organizational image]" />
    </div>
  </section>

  <section class="section-pad bg-bema-khaki-light/20">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">Core values</p>
        <h2>[PLACEHOLDER: Core Values section heading]</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {values.map((value) => (
          <article class="card p-6">
            <svg viewBox="0 0 24 24" class="mb-5 h-10 w-10 text-bema-green" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d={value.path} stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <h3 class="text-2xl">{value.heading}</h3>
            <p class="mt-4 text-bema-green/85">{value.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-bema-white">
    <div class="container">
      <div class="max-w-4xl">
        <p class="eyebrow">Coordination model</p>
        <h2 class="mt-3">[PLACEHOLDER: &quot;How BEMA Works&quot; or equivalent]</h2>
        <p class="mt-6 text-lg text-bema-green/85">[PLACEHOLDER: 2 paragraphs - BEMA coordinates, partner clinics deliver, no direct care]</p>
        <div class="mt-8 border-l-4 border-bema-khaki bg-bema-khaki-light/20 p-6 text-lg font-medium text-bema-green">
          BEMA does not deliver medical care directly. BEMA connects members to a network of independent partner clinics. The clinic provides the care. BEMA handles the coordination.
        </div>
      </div>
    </div>
  </section>

  <TeamList />
</BaseLayout>
