---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ImagePlaceholder from "../../components/UI/ImagePlaceholder.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/dateUtils";

const allPosts = await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true);
const posts = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
---

<BaseLayout
  title="From the Blog | BEMA - Healthcare Access for Florida's Working Families"
  description="[PLACEHOLDER: Blog page SEO description - 120 to 155 characters]"
>
  <section class="bg-bema-green py-16 text-bema-white md:py-24">
    <div class="container">
      <div class="max-w-4xl">
        <h1 class="text-bema-white">From the Blog</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-bema-white/90 md:text-xl">
          [PLACEHOLDER: Blog subheading - insights on healthcare access, the working gap, and the BEMA mission]
        </p>
      </div>
    </div>
  </section>

  <section class="section-pad bg-bema-white">
    <div class="container">
      <div class="grid gap-8 lg:grid-cols-4">
        <aside class="lg:col-span-1">
          <div class="card sticky top-24 p-6">
            <h2 class="font-body text-xl font-semibold">Filter Posts</h2>

            <div class="mt-6">
              <label for="search" class="mb-2 block text-sm font-medium text-bema-green">Search</label>
              <input id="search" type="text" placeholder="Search posts" class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-2 text-bema-green" />
            </div>

            {tags.length > 0 && (
              <div class="mt-6">
                <h3 class="font-body text-sm font-semibold text-bema-green">Tags</h3>
                <div class="mt-3 space-y-2">
                  {tags.map((tag) => (
                    <label class="flex items-center gap-2 text-sm text-bema-green">
                      <input type="checkbox" class="tag-checkbox h-4 w-4 rounded border-bema-khaki text-bema-green" value={tag} />
                      <span>{tag}</span>
                    </label>
                  ))}
                </div>
              </div>
            )}

            <div class="mt-6">
              <label for="author" class="mb-2 block text-sm font-medium text-bema-green">Author</label>
              <input id="author" type="text" placeholder="Filter by author" class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-2 text-bema-green" />
            </div>

            <div class="mt-6 space-y-3">
              <p class="text-sm font-medium text-bema-green">Date Range</p>
              <div>
                <label for="from-date" class="mb-1 block text-xs text-bema-green/75">From</label>
                <input id="from-date" type="date" class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-2 text-bema-green" />
              </div>
              <div>
                <label for="to-date" class="mb-1 block text-xs text-bema-green/75">To</label>
                <input id="to-date" type="date" class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-2 text-bema-green" />
              </div>
            </div>

            <button id="reset-filters" class="mt-6 w-full rounded-md border border-bema-green bg-bema-white px-4 py-2 text-sm font-medium text-bema-green transition-colors hover:border-bema-khaki">
              Reset Filters
            </button>
          </div>
        </aside>

        <div class="lg:col-span-3">
          <h2 class="font-body text-2xl font-semibold">All Posts</h2>
          <div id="posts-grid" class="mt-6 grid gap-8 md:grid-cols-2">
            {posts.map((post) => (
              <article
                class="blog-card card flex h-full flex-col"
                data-tags={post.data.tags.join(",")}
                data-author={post.data.author}
                data-date={post.data.pubDate.toISOString().slice(0, 10)}
              >
                <a href={`/blog/${post.slug}`}>
                  {post.data.image?.url ? (
                    <img
                      src={post.data.image.url}
                      alt={post.data.image.alt}
                      class="h-56 w-full rounded-t-lg object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <ImagePlaceholder label={post.data.image?.alt || "[PLACEHOLDER: Featured blog image]"} minHeight="min-h-56" class="rounded-b-none border-x-0 border-t-0" />
                  )}
                </a>
                <div class="flex flex-1 flex-col p-6">
                  <p class="text-sm font-medium text-bema-khaki">{formatDate(post.data.pubDate)} / {post.data.author}</p>
                  <h3 class="mt-3 text-2xl"><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
                  <p class="mt-4 flex-1 text-bema-green/85">{post.data.description}</p>
                  <div class="mt-5 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-md border border-bema-khaki/50 px-2 py-1 text-xs font-semibold text-bema-green">{tag}</span>
                    ))}
                  </div>
                  <a href={`/blog/${post.slug}`} class="mt-6 font-semibold text-bema-green underline decoration-bema-khaki underline-offset-4 hover:text-bema-green-dark">
                    Read More
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div id="no-results" class="mt-8 hidden rounded-lg border border-bema-khaki/40 bg-bema-khaki-light/20 p-8 text-center">
            <p>No posts match your search criteria. Please try different filters.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const searchInput = document.getElementById("search");
      const authorInput = document.getElementById("author");
      const tagCheckboxes = document.querySelectorAll(".tag-checkbox");
      const fromDateInput = document.getElementById("from-date");
      const toDateInput = document.getElementById("to-date");
      const resetButton = document.getElementById("reset-filters");
      const noResults = document.getElementById("no-results");
      const blogCards = document.querySelectorAll(".blog-card");

      const filterPosts = () => {
        const searchTerm = searchInput?.value.toLowerCase() || "";
        const authorTerm = authorInput?.value.toLowerCase() || "";
        const fromDate = fromDateInput?.value || "";
        const toDate = toDateInput?.value || "";
        const selectedTags = Array.from(tagCheckboxes).filter((checkbox) => checkbox.checked).map((checkbox) => checkbox.value);
        let visibleCount = 0;

        blogCards.forEach((card) => {
          const title = card.querySelector("h3")?.textContent.toLowerCase() || "";
          const description = card.querySelector("p")?.textContent.toLowerCase() || "";
          const author = card.getAttribute("data-author")?.toLowerCase() || "";
          const date = card.getAttribute("data-date") || "";
          const tags = (card.getAttribute("data-tags") || "").split(",");
          const matchesSearch = title.includes(searchTerm) || description.includes(searchTerm);
          const matchesAuthor = !authorTerm || author.includes(authorTerm);
          const matchesFromDate = !fromDate || date >= fromDate;
          const matchesToDate = !toDate || date <= toDate;
          const matchesTags = selectedTags.length === 0 || selectedTags.some((tag) => tags.includes(tag));

          if (matchesSearch && matchesAuthor && matchesFromDate && matchesToDate && matchesTags) {
            card.classList.remove("hidden");
            visibleCount++;
          } else {
            card.classList.add("hidden");
          }
        });

        noResults?.classList.toggle("hidden", visibleCount !== 0);
      };

      searchInput?.addEventListener("input", filterPosts);
      authorInput?.addEventListener("input", filterPosts);
      tagCheckboxes.forEach((checkbox) => checkbox.addEventListener("change", filterPosts));
      fromDateInput?.addEventListener("change", filterPosts);
      toDateInput?.addEventListener("change", filterPosts);
      resetButton?.addEventListener("click", () => {
        if (searchInput) searchInput.value = "";
        if (authorInput) authorInput.value = "";
        tagCheckboxes.forEach((checkbox) => { checkbox.checked = false; });
        if (fromDateInput) fromDateInput.value = "";
        if (toDateInput) toDateInput.value = "";
        filterPosts();
      });
    });
  </script>
</BaseLayout>
