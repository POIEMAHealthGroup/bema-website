---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";

const subjects = ["General Inquiry", "Member Services", "Employer Inquiry", "Clinic Partnership", "Media"];
---

<BaseLayout
  title="Contact | BEMA - Healthcare Access for Florida's Working Families"
  description="Have questions about BEMA membership or the partner clinic network? Reach out to the BEMA team and we will help you find your next step."
>
  <PageHeader
    title="We are here when you are ready to talk."
    subtitle="Whether you are exploring membership for yourself, your family, or your team, the BEMA team is ready to answer your questions and help you find the right next step."
    imageSrc="/images/BEMA-Misc4.jpg"
    imageAlt="A warm and approachable office setting in Florida, professional and welcoming, not clinical."
  />

  <section class="section-pad bg-bema-white">
    <div class="container grid gap-12 lg:grid-cols-[minmax(0,1.35fr)_minmax(280px,0.65fr)]">
      <div class="card p-6 md:p-8">
        <h2>Send Us a Message</h2>
        <!-- TODO: Wire to form handler (Netlify Forms, Formspree, or equivalent) at deployment -->
        <form id="contact-form" action="#" method="post" class="mt-8 space-y-6">
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-bema-green">Name</label>
            <input id="name" name="name" type="text" required class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-3 text-bema-green" />
          </div>

          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-bema-green">Email</label>
            <input id="email" name="email" type="email" required class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-3 text-bema-green" />
          </div>

          <div>
            <label for="phone" class="mb-2 block text-sm font-medium text-bema-green">Phone (optional)</label>
            <input id="phone" name="phone" type="tel" class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-3 text-bema-green" />
          </div>

          <div>
            <label for="subject" class="mb-2 block text-sm font-medium text-bema-green">Subject</label>
            <select id="subject" name="subject" required class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-3 text-bema-green">
              <option value="">Please select</option>
              {subjects.map((subject) => <option value={subject}>{subject}</option>)}
            </select>
          </div>

          <div>
            <label for="message" class="mb-2 block text-sm font-medium text-bema-green">Message</label>
            <textarea id="message" name="message" rows="6" required class="w-full rounded-md border border-bema-khaki/60 bg-bema-white px-4 py-3 text-bema-green"></textarea>
            <p class="mt-3 rounded-md border border-bema-khaki/40 bg-bema-khaki-light/20 p-3 text-sm font-medium text-bema-green">
              Please do not include personal health information in this form.
            </p>
          </div>

          <Button type="submit">Send Message</Button>
        </form>
      </div>

      <aside class="card p-6 md:p-8">
        <h2 class="font-body text-2xl font-semibold">Contact Info</h2>
        <dl class="mt-6 space-y-6">
          <div>
            <dt class="font-semibold text-bema-khaki">Phone</dt>
            <dd class="mt-1">[PLACEHOLDER: Phone number]</dd>
          </div>
          <div>
            <dt class="font-semibold text-bema-khaki">Email</dt>
            <dd class="mt-1">[PLACEHOLDER: General contact email]</dd>
          </div>
          <div>
            <dt class="font-semibold text-bema-khaki">Location</dt>
            <dd class="mt-1">Florida</dd>
          </div>
          <div>
            <dt class="font-semibold text-bema-khaki">Hours</dt>
            <dd class="mt-1">[PLACEHOLDER: Office hours]</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>
</BaseLayout>
