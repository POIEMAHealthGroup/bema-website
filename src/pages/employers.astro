---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";

const employerCards = [
  {
    heading: "No surprises on the balance sheet.",
    body: "BEMA employer memberships operate on a fixed monthly program service fee per employee. No claims processing, no unpredictable cost spikes, and no end of year reconciliation. You know exactly what you are paying and exactly what your team is getting.",
  },
  {
    heading: "Healthy employees show up and stay.",
    body: "When employees have consistent access to primary care, eye care, and Mental Health services they use them. That means fewer sick days, fewer untreated conditions that become bigger problems, and a workforce that feels valued enough to stay.",
  },
  {
    heading: "Your benefit dollars do more than you think.",
    body: "Every BEMA employer membership is part of a larger mission. BEMA's coordination model supports Florida's working gap population, the people who are employed and contributing but priced out of the current system. Choosing BEMA is a workforce decision and a community one.",
  },
];
---

<!-- PHASE 1.1: Employers page structure. Placeholder content to be populated separately. -->
<BaseLayout
  title="For Employers | BEMA - Healthcare Access for Florida's Working Families"
  description="BEMA gives Florida employers a simple way to extend coordinated healthcare access to their workforce with no claims, no deductibles, and no administrative burden."
>
  <PageHeader
    title="For Employers"
    subtitle="BEMA gives Florida employers a simple, predictable way to extend coordinated healthcare access to their workforce without the complexity of traditional group insurance."
    imageSrc="/images/employers-program.jpg"
    imageAlt="A professional workplace setting in Florida with a diverse team of employees, clean and modern, not clinical."
  />

  <section class="section-pad bg-bema-white">
    <div class="container">
      <figure class="mx-auto max-w-4xl text-center">
        <blockquote class="font-display text-3xl font-bold leading-tight text-bema-green md:text-5xl">
          Your employees are working hard. The least the system can do is work for them too.
        </blockquote>
        <figcaption class="mt-6 font-semibold text-bema-khaki">The BEMA Employer Program</figcaption>
      </figure>
    </div>
  </section>

  <section class="section-pad bg-bema-white">
    <div class="container grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="eyebrow">THE PROGRAM</p>
        <h2 class="mt-3">A workforce benefit that actually benefits your workforce.</h2>
        <p class="mt-6 text-lg text-bema-green/85">The BEMA employer program gives Florida businesses a straightforward way to extend coordinated healthcare access to their teams. Employees gain access to Direct Primary Care, Eye Care, and Mental Health services through BEMA's partner clinic network under a fixed monthly program service fee. No claims. No deductibles. No administrative burden on your HR team. BEMA handles everything between the employee and the care they need. Enrollment is simple, costs are predictable, and your team gets access to consistent care that keeps them healthier, more present, and more productive. For small and mid size Florida employers who want to do right by their people without taking on the complexity of traditional group coverage, BEMA is built for exactly that.</p>
      </div>
      <img
        src="/images/employers-program.jpg"
        alt="A small business owner in a professional Florida office setting, engaged and confident, speaking with a team member."
        class="min-h-80 w-full rounded-lg border border-bema-khaki/40 object-cover"
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>

  <section class="section-pad bg-bema-khaki-light/20">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">Why employers choose BEMA</p>
        <h2>Three reasons Florida employers are making the switch.</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        {employerCards.map((card) => (
          <article class="card p-6">
            <svg viewBox="0 0 24 24" class="mb-5 h-10 w-10 text-bema-green" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="12" cy="12" r="8"></circle>
              <path d="M8 12h8M12 8v8" stroke-linecap="round"></path>
            </svg>
            <h3 class="text-2xl">{card.heading}</h3>
            <p class="mt-4 text-bema-green/85">{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bema-green py-16 text-bema-white">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-bema-white">Your team deserves better than what the current system offers. Let us show you what BEMA looks like for your business.</h2>
        <div class="mt-8">
          <Button href="/contact" variant="inverted">Contact Us to Learn More</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
