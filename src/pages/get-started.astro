---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";

const faqs = [1, 2, 3, 4, 5];
---

<BaseLayout
  title="Get Started | BEMA - Healthcare Access for Florida's Working Families"
  description="[PLACEHOLDER: Get Started page SEO description - 120 to 155 characters]"
>
  <PageHeader
    title="[PLACEHOLDER: Get Started headline - welcoming, plain language, relief-emotion framing]"
    subtitle="[PLACEHOLDER: 1 sentence - what happens next when you reach out]"
  />

  <section class="section-pad bg-bema-white">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">How to get started</p>
        <h2>[PLACEHOLDER: How to Get Started section heading]</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        {[1, 2, 3].map((step) => (
          <article class="card p-6">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-md bg-bema-green font-semibold text-bema-white">{step}</div>
            <h3 class="text-2xl">[PLACEHOLDER: Step {step} title - {step === 1 ? "reaching out or getting information" : step === 2 ? "being matched or connected" : "accessing care through a partner clinic"}]</h3>
            <p class="mt-4 text-bema-green/85">[PLACEHOLDER: Step {step} description - 2 sentences]</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-bema-khaki-light/20">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">Questions</p>
        <h2>[PLACEHOLDER: FAQ section heading]</h2>
      </div>
      <div class="mx-auto max-w-4xl space-y-4">
        {faqs.map((item) => (
          <details class="card group p-6">
            <summary class="flex cursor-pointer items-center justify-between gap-6">
              <h3 class="text-xl">[PLACEHOLDER: FAQ question {item}]</h3>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 flex-none text-bema-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <p class="mt-4 text-bema-green/85">[PLACEHOLDER: FAQ answer {item}]</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bema-green py-16 text-bema-white">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-bema-white">[PLACEHOLDER: &quot;Ready to take the first step?&quot; or equivalent]</h2>
        <div class="mt-8">
          <Button href="/contact" variant="inverted">Contact Us</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
