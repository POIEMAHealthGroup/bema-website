---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";

const faqs = [1, 2, 3, 4, 5];
---

<BaseLayout
  title="Get Started | BEMA - Healthcare Access for Florida's Working Families"
  description="BEMA membership gives working families in Florida coordinated access to Direct Primary Care, Eye Care, and Mental Health services. No insurance required. Get started today."
>
  <PageHeader
    title="This is where accessing your healthcare is easy."
    subtitle="Connect now and a member of the BEMA team will walk you through how membership works, what services are available in your area, and what your next step looks like."
    imageSrc="/images/home-who-we-serve.jpg"
    imageAlt="A working adult in a bright Florida setting looking relaxed and hopeful, warm and approachable, not clinical."
  />

  <section class="section-pad bg-bema-white">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">How to get started</p>
        <h2>Three steps to getting the care you deserve.</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        {[1, 2, 3].map((step) => (
          <article class="card p-6">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-md bg-bema-green font-semibold text-bema-white">{step}</div>
            <h3 class="text-2xl">{step === 1 ? "Reach out to the BEMA team." : step === 2 ? "We find the right partner clinic for you." : "Walk in as a member and get the care you need."}</h3>
            <p class="mt-4 text-bema-green/85">{step === 1 ? "Fill out the contact form or give us a call and a BEMA team member will get back to you promptly. There is no paperwork, no commitment, and no pressure at this stage." : step === 2 ? "BEMA reviews your needs and connects you to the right partner clinic in your area for the services you are looking for. We handle the coordination so you do not have to figure out where to go or who to call." : "Your partner clinic is expecting you. Show up, be seen, and leave without a surprise bill waiting for you on the other side."}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-bema-khaki-light/20">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">Questions</p>
        <h2>Questions we hear most often.</h2>
      </div>
      <div class="mx-auto max-w-4xl space-y-4">
        {faqs.map((item) => (
          <details class="card group p-6">
            <summary class="flex cursor-pointer items-center justify-between gap-6">
              <h3 class="text-xl">{item === 1 ? "Who is BEMA for?" : item === 2 ? "Is BEMA insurance?" : item === 3 ? "Do I need to have insurance to join BEMA?" : item === 4 ? "What happens after I sign up?" : "Can my employer offer BEMA to our team?"}</h3>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 flex-none text-bema-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <p class="mt-4 text-bema-green/85">{item === 1 ? "BEMA is for working individuals and families in Florida who earn too much to qualify for Medicaid but cannot absorb what traditional insurance costs today. If you have gone without a primary care doctor because the system made it too expensive or too complicated to access one, BEMA was built for you." : item === 2 ? "No. BEMA is not an insurance company and not an insurance product of any kind. BEMA is a coordination organization. We coordinate access to Direct Primary Care, Eye Care, and Mental Health services through a network of independent partner clinics. You pay a monthly program service fee for coordinated access to that network. There are no claims, no deductibles, and no insurance approval required to get care." : item === 3 ? "No. BEMA membership is open to anyone regardless of insurance status. If you have existing coverage, BEMA works alongside it. If you do not, BEMA stands on its own. The only requirement is that you are a working individual or family in Florida looking for a better way to access care." : item === 4 ? "Once you become a member BEMA connects you to the right partner clinics for your needs and handles the coordination from there. You will know exactly where to go, who to see, and what to expect before your first visit. No runaround, no paperwork maze, no surprise bills." : "Yes. BEMA works with Florida employers who want to extend coordinated healthcare access to their workforce as part of a benefits strategy. Employer memberships operate on the same program service fee model with no claims processing and no administrative burden on the employer. Visit our Employers page to learn more."}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bema-green py-16 text-bema-white">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-bema-white">The first step is the easiest one you will take.</h2>
        <div class="mt-8">
          <Button href="/contact" variant="inverted">Contact Us</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
