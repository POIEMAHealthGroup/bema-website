---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import RecentBlogPosts from "../components/Sections/RecentBlogPosts.astro";
import Button from "../components/UI/Button.astro";

const pageTitle = "Home | BEMA - Healthcare Access for Florida's Working Families";
const pageDescription = "[PLACEHOLDER: Home page SEO description - 120 to 155 characters]";

const steps = [1, 2, 3];
const services = [
  {
    id: "primary-care",
    icon: "PC",
    heading: "[PLACEHOLDER: Direct Primary Care heading]",
    body: "[PLACEHOLDER: 1 sentence description]",
    href: "/services#primary-care",
  },
  {
    id: "eye-care",
    icon: "EC",
    heading: "[PLACEHOLDER: Eye Care heading]",
    body: "[PLACEHOLDER: 1 sentence description]",
    href: "/services#eye-care",
  },
  {
    id: "mental-health",
    icon: "MH",
    heading: "[PLACEHOLDER: Mental Health heading]",
    body: "[PLACEHOLDER: 1 sentence description]",
    href: "/services#mental-health",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <HeroSection imageSrc="/images/home-hero.jpeg" />

  <section id="how-it-works" class="section-pad bg-bema-khaki-light/20">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">How it works</p>
        <h2 class="mt-3">[PLACEHOLDER: Section heading for the coordination model explanation]</h2>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {steps.map((step) => (
          <article class="card p-6">
            <svg viewBox="0 0 64 64" class="mb-6 h-16 w-16 text-bema-green" aria-hidden="true">
              <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="2"></circle>
              <text x="32" y="40" text-anchor="middle" class="fill-current font-body text-2xl font-semibold">{step}</text>
            </svg>
            <h3 class="text-2xl">[PLACEHOLDER: Step {step} title]</h3>
            <p class="mt-4 text-bema-green/85">[PLACEHOLDER: Step {step} description - 2 sentences]</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-bema-white">
    <div class="container grid gap-12 lg:grid-cols-2 lg:items-center">
      <img
        src="/images/home-who-we-serve.jpg"
        alt="[PLACEHOLDER: Alt text for working individual or family in a non-clinical setting]"
        class="min-h-80 w-full rounded-lg border border-bema-khaki/40 object-cover"
        loading="lazy"
        decoding="async"
      />
      <div>
        <p class="eyebrow">Who we serve</p>
        <h2 class="mt-3">[PLACEHOLDER: &quot;Who We Serve&quot; heading]</h2>
        <p class="mt-6 text-lg text-bema-green/85">[PLACEHOLDER: 2 paragraph description of the working gap population - individuals and families who earn too much for Medicaid and too little to absorb traditional care costs]</p>
        <div class="mt-8">
          <Button href="/services">See Our Services</Button>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-bema-white">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">Services</p>
        <h2>[PLACEHOLDER: Services preview heading]</h2>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {services.map((service) => (
          <article class="card flex h-full flex-col p-6" id={service.id}>
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-md border border-bema-khaki/50 bg-bema-khaki-light/30 font-semibold text-bema-green">
              {service.icon}
            </div>
            <h3 class="text-2xl">{service.heading}</h3>
            <p class="mt-4 flex-1 text-bema-green/85">{service.body}</p>
            <a class="mt-6 font-semibold text-bema-green underline decoration-bema-khaki underline-offset-4 hover:text-bema-green-dark" href={service.href}>Learn More</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bema-green py-16 text-bema-white">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-bema-white">[PLACEHOLDER: Employer-facing value proposition headline - ROI and workforce health framing]</h2>
        <p class="mt-5 max-w-3xl text-lg text-bema-white/85">[PLACEHOLDER: 1 sentence - predictable costs, retention, CSR framing]</p>
        <div class="mt-8">
          <Button href="/employers" variant="inverted">Employer Information</Button>
        </div>
      </div>
    </div>
  </section>

  <RecentBlogPosts />

  <section class="bg-bema-khaki-light/25 py-16">
    <div class="container">
      <div class="max-w-4xl">
        <h2>[PLACEHOLDER: Closing CTA heading - warm, community-first]</h2>
        <p class="mt-5 max-w-3xl text-lg text-bema-green/85">[PLACEHOLDER: 1 sentence invitation]</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/get-started">Get Started</Button>
          <Button href="/contact" variant="outline">Contact Us</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
