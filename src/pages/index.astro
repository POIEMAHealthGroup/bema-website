---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import RecentBlogPosts from "../components/Sections/RecentBlogPosts.astro";
import Button from "../components/UI/Button.astro";

const pageTitle = "Home | BEMA - Healthcare Access for Florida's Working Families";
const pageDescription = "BEMA coordinates access to Direct Primary Care, Eye Care, and Mental Health services for working families in Florida who have been priced out of what healthcare currently costs.";

const steps = [1, 2, 3];
const services = [
  {
    id: "primary-care",
    icon: "PC",
    heading: "Direct Primary Care",
    body: "Consistent, relationship based primary care through a partner clinic that knows you by name, not by a billing code.",
    href: "/services#primary-care",
  },
  {
    id: "eye-care",
    icon: "EC",
    heading: "Eye Care",
    body: "Routine and preventive eye care coordinated through BEMA's partner clinic network, accessible to every member.",
    href: "/services#eye-care",
  },
  {
    id: "mental-health",
    icon: "MH",
    heading: "Mental Health",
    body: "Coordinated access to licensed Mental Health professionals who are focused on your care, not on the administrative maze around it.",
    href: "/services#mental-health",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <HeroSection imageSrc="/images/home-hero.jpeg" />

  <section id="how-it-works" class="section-pad bg-bema-khaki-light/20">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">How it works</p>
        <h2 class="mt-3">How BEMA Works</h2>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {steps.map((step) => (
          <article class="card p-6">
            <svg viewBox="0 0 64 64" class="mb-6 h-16 w-16 text-bema-green" aria-hidden="true">
              <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="2"></circle>
              <text x="32" y="40" text-anchor="middle" class="fill-current font-body text-2xl font-semibold">{step}</text>
            </svg>
            <h3 class="text-2xl">{step === 1 ? "You become a member." : step === 2 ? "We handle the coordination." : "Your partner clinic takes it from there."}</h3>
            <p class="mt-4 text-bema-green/85">{step === 1 ? "Choose a monthly program service fee that fits your budget. Membership gives you coordinated access to BEMA's full partner clinic network covering Direct Primary Care, Eye Care, and Mental Health services." : step === 2 ? "BEMA matches you to the right partner clinic for your needs and takes care of the logistics in between. No referral runaround, no paperwork maze, no surprise bills waiting on the other side." : "Walk in as a member, not as someone navigating a broken system. The clinic focuses entirely on your care because BEMA has already handled everything else."}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-bema-white">
    <div class="container grid gap-12 lg:grid-cols-2 lg:items-center">
      <img
        src="/images/home-who-we-serve.jpg"
        alt="[PLACEHOLDER: Alt text for working individual or family in a non-clinical setting]"
        class="min-h-80 w-full rounded-lg border border-bema-khaki/40 object-cover"
        loading="lazy"
        decoding="async"
      />
      <div>
        <p class="eyebrow">Who we serve</p>
        <h2 class="mt-3">If the system has never quite worked for you, you are not alone.</h2>
        <p class="mt-6 text-lg text-bema-green/85">There is a gap in American healthcare that nobody talks about enough. You earn too much to qualify for Medicaid but not enough to make what most plans cost today worth it. You are working, you are contributing, and the system has left you to figure it out on your own.</p>
        <p class="mt-6 text-lg text-bema-green/85">BEMA was built for exactly that gap. We coordinate access to Direct Primary Care, Eye Care, and Mental Health services for working individuals and families in Florida who deserve consistent, dignified care without the financial weight that comes with it.</p>
        <div class="mt-8">
          <Button href="/services">See Our Services</Button>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-bema-white">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow">Services</p>
        <h2>Three services. One coordinated membership.</h2>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {services.map((service) => (
          <article class="card flex h-full flex-col p-6" id={service.id}>
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-md border border-bema-khaki/50 bg-bema-khaki-light/30 font-semibold text-bema-green">
              {service.icon}
            </div>
            <h3 class="text-2xl">{service.heading}</h3>
            <p class="mt-4 flex-1 text-bema-green/85">{service.body}</p>
            <a class="mt-6 font-semibold text-bema-green underline decoration-bema-khaki underline-offset-4 hover:text-bema-green-dark" href={service.href}>Learn More</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bema-green py-16 text-bema-white">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-bema-white">Your employees need reliable healthcare access. Your bottom line needs predictability. BEMA makes both possible.</h2>
        <p class="mt-5 max-w-3xl text-lg text-bema-white/85">BEMA gives Florida employers a simple way to extend coordinated healthcare access to their workforce at a fixed monthly program service fee with no claims processing, no unpredictable costs, and no administrative burden.</p>
        <div class="mt-8">
          <Button href="/employers" variant="inverted">Employer Information</Button>
        </div>
      </div>
    </div>
  </section>

  <RecentBlogPosts />

  <section class="bg-bema-khaki-light/25 py-16">
    <div class="container">
      <div class="max-w-4xl">
        <h2>You have been navigating this on your own for long enough.</h2>
        <p class="mt-5 max-w-3xl text-lg text-bema-green/85">BEMA is here to make getting care simpler, more predictable, and less expensive than anything the current system has offered you.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/get-started">Get Started</Button>
          <Button href="/contact" variant="outline">Contact Us</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
